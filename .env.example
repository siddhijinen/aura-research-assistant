# ==============================================================================
# AuRA: Environment Configuration Template
# Copy this file to '.env' and fill in your keys.
# ==============================================================================

# Google Gemini API Configuration
GEMINI_API_KEY=

# Tavily Search API Configuration
TAVILY_API_KEY=

# Neo4j Aura Graph Database Configuration (Required for Knowledge Graph Storage)
NEO4J_URI=
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=

# Application Settings
ENV=development
LOG_LEVEL=INFO

# Semantic Scholar API Configuration (Optional: provides higher rate limits for scholar queries)
# Get a key from: https://www.semanticscholar.org/product/api#api-key-form
SEMANTIC_SCHOLAR_API_KEY=
